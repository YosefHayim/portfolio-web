# OpenAI API key used by backend LLM endpoints.
OPENAI_API_KEY=sk-your-api-key-here

# Backend HTTP port exposed by the Node API process.
PORT=3000
# Runtime mode for logging and framework behavior.
NODE_ENV=development

# Allowed frontend origin(s) for CORS, comma-separated if multiple.
FRONTEND_URL=http://localhost:5173

# Named AWS CLI profile used by infra scripts.
AWS_PROFILE=default
# AWS region where EC2 and networking resources are created.
AWS_REGION=eu-central-1
# Apex domain for the website DNS record.
DOMAIN_ROOT=yosefhayimsabag.com
# API domain that points to the same EC2 host via nginx.
API_SUBDOMAIN=api.yosefhayimsabag.com
# Public backend origin baked into the Vite production build.
VITE_API_URL=https://api.yosefhayimsabag.com
# Route53 hosted zone ID for DOMAIN_ROOT.
HOSTED_ZONE_ID=ZXXXXXXXXXXXXXXXXXXXX
# EC2 Name tag for the created instance.
INSTANCE_NAME=portfolio-prod
# EC2 machine size for the portfolio host.
INSTANCE_TYPE=t3.small
# CPU architecture for AMI lookup; use x86_64 for t3.*
ARCH=x86_64
# Optional explicit AMI ID; leave empty for latest AL2023 auto-resolve.
AMI_ID=
# Public subnet ID where the instance will be launched.
SUBNET_ID=subnet-xxxxxxxxxxxxxxxxx
# VPC ID used when creating a security group automatically.
VPC_ID=vpc-xxxxxxxxxxxxxxxxx
# Existing EC2 key pair name used for SSH access.
KEY_NAME=your-existing-keypair-name
# Optional existing security group ID; leave empty to auto-create one.
SECURITY_GROUP_ID=
# CIDR allowed to SSH to the instance (use your IP/32).
SSH_CIDR=0.0.0.0/0
# Git repository cloned on the EC2 host during bootstrap.
REPO_URL=https://github.com/YosefHayim/portfolio.git
# Absolute path on EC2 where the repo is deployed.
APP_DIR=/opt/portfolio

# SMTP username used by contact form email sending.
EMAIL_USER=
# SMTP app password/token used by contact form email sending.
EMAIL_PASS=
